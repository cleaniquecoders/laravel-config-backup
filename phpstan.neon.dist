includes:
    - phpstan-baseline.neon

parameters:
    level: 5
    paths:
        - src
    # The optional Livewire UI is the presentation layer: it requires the host's
    # Flux peer dependency to function and references a package-namespaced Blade
    # view that PHPStan/Larastan cannot resolve to a `view-string` in isolation.
    # Its logic delegates to ConfigBackupService, which is fully analysed + tested.
    excludePaths:
        - src/Livewire/ConfigBackup.php
    tmpDir: build/phpstan
